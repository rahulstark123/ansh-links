// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  workspaceId   Int      @unique @default(autoincrement())
  email         String   @unique
  handle        String?  @unique
  fullName      String?
  avatarUrl     String?
  authProvider  String   @default("google")
  authSubjectId String?  @unique
  lastLoginAt   DateTime?
  loginCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  products      Product[]
  categories    ProductCategory[]
  socialLinks   SocialLink[]
  cards         Card[]

  @@map("users")
}

model Card {
  id                 String   @id @default(cuid())
  userId             String
  workspaceId        Int
  cardSlug           String
  isLive             Boolean  @default(false)
  title              String
  bio                String?
  profileImageUrl    String?
  coverImageUrl      String?
  designId           String   @default("default")
  defaultThemeId     String   @default("aurora")
  status             String   @default("Draft")
  showProfilePhoto   Boolean  @default(true)
  showAvatarBadge    Boolean  @default(true)
  showBio            Boolean  @default(true)
  showSocialChips    Boolean  @default(true)
  aboutWhatIDo       String?
  aboutInterests     Json?
  aboutEducation     String?
  aboutLocation      String?
  links              Json?
  selectedProductIds Json?
  productVisibility  Json?
  selectedSocialIds  Json?
  socialVisibility   Json?
  settings           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@unique([workspaceId, cardSlug])
  @@map("cards")
}

model Product {
  id          String   @id @default(cuid())
  userId      String
  workspaceId Int
  categoryId  String
  name        String
  description String?
  linkUrl     String?
  currency    String
  amount      Float
  imageUrl    String?
  useInLinks  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("products")
}

model ProductCategory {
  id          String    @id @default(cuid())
  userId      String
  workspaceId Int
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([workspaceId, name])
  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("product_categories")
}

model SocialLink {
  id               String   @id @default(cuid())
  userId           String
  workspaceId      Int
  platform         String
  accountName      String?
  customPlatform   String?
  url              String
  useInCardBuilder Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("social_links")
}
